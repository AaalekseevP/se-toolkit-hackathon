<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Enter Password</title>
  <%- include('partials/theme-init') %>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme"></button>

  <div class="header">
    <div class="author-badge">By Roman Alekseev<br>Innopolis University</div>
    <h1>🔒 Protected Meeting</h1>
  </div>
  <div class="container">
    <div class="card">
      <h2>Enter password</h2>
      <div class="meeting-info">
        <strong><%= meeting.title %></strong>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="error-msg">❌ <%= error %></div>
      <% } %>

      <form method="POST" action="/check-password/<%= meeting.unique_id %>">
        <input type="hidden" name="redirectUrl" value="<%= redirectUrl %>">
        <label class="field-label" for="password">Password:</label>
        <input type="password" id="password" name="password" required placeholder="Enter password" autofocus>
        <button type="submit" class="submit-btn" style="margin-top:20px;">Unlock</button>
      </form>
    </div>
    <a href="/" class="back-link">← Back to Home</a>
  </div>

  <script src="/theme.js"></script>
</body>
</html>
