<script>
  (function() {
    var s = localStorage.getItem('theme');
    var p = window.matchMedia('(prefers-color-scheme: dark)').matches;
    var t = s || (p ? 'dark' : 'light');
    document.documentElement.setAttribute('data-theme', t);
    // Inline critical background to prevent flash before CSS loads
    document.documentElement.style.background = t === 'dark' ? '#1a1a2e' : '#f0f2f5';
    document.documentElement.style.color = t === 'dark' ? '#e0e0e0' : '#333333';
  })();
</script>
<style>
  /* Critical styles loaded immediately */
  html { background: #f0f2f5; }
  [data-theme="dark"] html, html[data-theme="dark"] { background: #1a1a2e !important; }
  body { background: var(--bg, #f0f2f5); margin: 0; min-height: 100vh; }
</style>
